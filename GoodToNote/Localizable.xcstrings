        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The action shows \"Amount\" and \"Merchant\" as blue fillable fields. Tap \"Amount\" and pick the trigger’s \"Amount\"; tap \"Merchant\" and pick \"Merchant\". You must connect \"Amount\", or nothing gets recorded."
          }
        },
